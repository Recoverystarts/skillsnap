# SkillSnap Backend Environment Variables

# Server
PORT=8080

# Gemini API (AI Studio - addict2influencer@gmail.com account)
GEMINI_API_KEY=your_gemini_api_key_here

# Database (Cloud SQL PostgreSQL)
# Option 1: Connection string (local dev / direct connection)
DATABASE_URL=postgresql://skillsnap:password@localhost:5432/skillsnap

# Option 2: Cloud SQL socket (Cloud Run auto-connects)
# CLOUD_SQL_CONNECTION_NAME=skillsnap-497316:us-central1:skillsnap-db
# DB_USER=skillsnap
# DB_PASSWORD=your_password
# DB_NAME=skillsnap

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Google Cloud Storage (for SOP file storage)
# GCS_BUCKET=skillsnap-sops

# Firebase Auth
# FIREBASE_PROJECT_ID=skillsnap-497316
